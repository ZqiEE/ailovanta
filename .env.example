# Ailovanta local development settings.
# Bootstrap chat can still use a local fallback model.
# Owned chat should route through runtime manifests and Ailovanta worker.

AILOVANTA_MODEL_STAGE=owned_runtime_candidate
AILOVANTA_OWNED_MODEL_READY=false

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=ailovanta-owned:candidate
OLLAMA_TIMEOUT_SECONDS=30

AILOVANTA_DEFAULT_WORKER_URL=http://127.0.0.1:9001
AILOVANTA_WORKER_TIMEOUT_SECONDS=60

# Optional external/local backend client, when api.model_backend_client is installed.
AILOVANTA_MODEL_BACKEND_URL=http://127.0.0.1:8001
AILOVANTA_MODEL_BACKEND_MODEL=ailovanta-owned:candidate
AILOVANTA_MODEL_BACKEND_TIMEOUT_SECONDS=120
