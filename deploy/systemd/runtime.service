[Unit]
Description=Ailovanta Runtime Node
After=network.target

[Service]
WorkingDirectory=/opt/ailovanta
EnvironmentFile=-/etc/ailovanta/ailovanta.env
ExecStart=/opt/ailovanta/.venv/bin/uvicorn api.runtime_server:app --host 0.0.0.0 --port 9001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
